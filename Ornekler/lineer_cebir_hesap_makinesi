    }
    if (m2 != NULL) {
        for (int i = 0; i < satır2; i++) free(m2[i]);
        free(m2);
    }
}

void çarpım() {
    int **m1 = matrisi_al();
    int **m2 = matrisi_al2();
    if (m1 == NULL || m2 == NULL || sütun != satır2) {
        printf("Hata: Matris boyutları çarpım için uygun değil.\n");
        return;
    }

    int **sonuc = (int **)malloc(satır * sizeof(int *));
    for (int i = 0; i < satır; i++) sonuc[i] = (int *)malloc(sütun2 * sizeof(int));

    for (int i = 0; i < satır; i++) {
        for (int j = 0; j < sütun2; j++) {
            sonuc[i][j] = 0;
            for (int k = 0; k < sütun; k++) {
                sonuc[i][j] += m1[i][k] * m2[k][j];
            }
        }
    }

    printf("\nÇarpım Sonucu:\n");
    for (int i = 0; i < satır; i++) {
        for (int j = 0; j < sütun2; j++) printf("%d ", sonuc[i][j]);
        printf("\n");
    }

    for (int i = 0; i < satır; i++) free(sonuc[i]);
    free(sonuc);
    for (int i = 0; i < satır; i++) free(m1[i]);
    free(m1);

    for (int i = 0; i < satır2; i++) free(m2[i]);
    free(m2);
}

void determinant() {
    int **m1 = matrisi_al();
    if (m1 == NULL || satır != sütun) {
        printf("Hata: Determinant hesaplamak için kare matris gereklidir.\n");
        return;
    }
    else {
        printf("\nDeterminant Sonucu: %d\n", determinant_hesap(m1, satır));
    }
    for (int i = 0; i < satır; i++) free(m1[i]);
    free(m1);
}
int determinant_hesap(int **matris, int boyut) {
    if (boyut == 1)
        return matris[0][0];
    if (boyut == 2)
        return matris[0][0] * matris[1][1] - matris[0][1] * matris[1][0];

    int det = 0, katsayı = 1;

    for (int i = 0; i < boyut; i++) {
        int **minor = (int **)malloc((boyut - 1) * sizeof(int *));
        for (int j = 0; j < boyut - 1; j++) {
            minor[j] = (int *)malloc((boyut - 1) * sizeof(int));
        }
        for (int j = 1; j < boyut; j++) {
            int alt_sütun = 0;
            for (int k = 0; k < boyut; k++) {
                if (k == i) continue;
                minor[j - 1][alt_sütun++] = matris[j][k];
            }
        }
        det += katsayı * matris[0][i] * determinant_hesap(minor, boyut - 1);
        katsayı = -katsayı;
        for (int k = 0; k < boyut - 1; k++) free(minor[k]);
        free(minor);
    }
    return det;
}
void transpoz() {
        int **m = matrisi_al();
