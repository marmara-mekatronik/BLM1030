void tamponu_temizle() {
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}

int **matrisi_al() {
    printf("Matrisinizin satır sayısını giriniz: ");
    if (scanf("%d", &satır) != 1 || satır <= 0) return NULL;
    tamponu_temizle();

    printf("Matrisinizin sütun sayısını giriniz: ");
    if (scanf("%d", &sütun) != 1 || sütun <= 0) return NULL;
    tamponu_temizle();

    int **matris = (int **)malloc(satır * sizeof(int *));
    for (int i = 0; i < satır; i++) {
        matris[i] = (int *)malloc(sütun * sizeof(int));
    }

    for (int i = 0; i < satır; i++) {
        for (int j = 0; j < sütun; j++) {
            printf("Matrisin %d. satir %d. sütun elemanini giriniz: ", i + 1, j + 1);
            scanf("%d", &matris[i][j]);
        }
    }
    printf("\n--- Girilen Matris ---\n");
    for (int i = 0; i < satır; i++) {
        for (int j = 0; j < sütun; j++) {
            printf("%d\t", matris[i][j]);
        }
        printf("\n");
    }
    return matris;
}

int **matrisi_al2() {
