    if (v1 == NULL || v2 == NULL) {
        printf("Hata: Vektörler alınamadı.\n");
        return;
    }else {
        double vektörel_x = v1[1] * v2[2] - v1[2] * v2[1];
        double vektörel_y = v1[2] * v2[0] - v1[0] * v2[2];
        double vektörel_z = v1[0] * v2[1] - v1[1] * v2[0];

        printf("\n1. Vektör: [%.2f, %.2f, %.2f]\n", v1[0], v1[1], v1[2]);
        printf("2. Vektör: [%.2f, %.2f, %.2f]\n", v2[0], v2[1], v2[2]);
        printf("\nVektörel Çarpım Sonucu: [%.2f, %.2f, %.2f]\n", vektörel_x, vektörel_y, vektörel_z);
    }
    free(v1);
    free(v2);
}

