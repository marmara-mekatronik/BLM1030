void vektör_açısı() {
    double *v1 = vektör_al();
    double *v2 = vektör_al();
    if (v1 == NULL || v2 == NULL) {
        printf("Hata: Vektörler alınamadı!\n");
        return;
    }else {
        double skaler = v1[0] * v2[0] + v1[1] * v2[1] + v1[2] * v2[2];
        double uzunluk_v1 = sqrt(v1[0] * v1[0] + v1[1] * v1[1] + v1[2] * v1[2]);
        double uzunluk_v2 = sqrt(v2[0] * v2[0] + v2[1] * v2[1] + v2[2] * v2[2]);

        if (uzunluk_v1 == 0 || uzunluk_v2 == 0) {
            printf("Hata: Uzunluğu sıfır olan bir vektör girdiniz.\n");
            free(v1);
            free(v2);
            return;
        }

        double cos_theta = skaler / (uzunluk_v1 * uzunluk_v2);
        if (cos_theta > 1) cos_theta = 1.00;
        if (cos_theta < -1) cos_theta = -1.00;

        double radyal_AÇI = acos(cos_theta);
        double angle_deg = radyal_AÇI * (180.0 / M_PI);

        printf("\n1. Vektör: [%.2f, %.2f, %.2f]\n", v1[0], v1[1], v1[2]);
        printf("2. Vektör: [%.2f, %.2f, %.2f]\n", v2[0], v2[1], v2[2]);
        printf("\nVektörler Arası Açı: %.2f derece\n", angle_deg);
    }
    free(v1);
    free(v2);
}
