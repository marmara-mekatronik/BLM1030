void toplam() {
    int **m1 = matrisi_al();
    int **m2 = matrisi_al2();
    if (m1 == NULL || m2 == NULL || satır != satır2 || sütun != sütun2) {
        printf("Boyutlar uyumsuz veya hata oluştu.\n");
    } else {
        printf("Toplama işlemi gerçekleştiriliyor...\n");
        for (int i = 0; i < satır; i++) {
            for (int j = 0; j < sütun; j++) {
                m1[i][j] = m1[i][j] + m2[i][j];
            }
        }
        printf("\nToplama Sonucu:\n");
        for (int i = 0; i < satır; i++) {
            for (int j = 0; j < sütun; j++) printf("%d ", m1[i][j]);
            printf("\n");
        }
    }
    if (m1 != NULL) {
        for (int i = 0; i < satır; i++) free(m1[i]);
        free(m1);
    }
    if (m2 != NULL) {
        for (int i = 0; i < satır2; i++) free(m2[i]);
        free(m2);
    }
}

void fark() {
    int **m1 = matrisi_al();
    int **m2 = matrisi_al2();
    if (m1 == NULL || m2 == NULL || satır != satır2 || sütun != sütun2) {
        printf("Boyutlar uyumsuz.");
    } else {
        printf("\nÇıkarma Sonucu:\n");
        for (int i = 0; i < satır; i++) {
            for (int j = 0; j < sütun; j++) printf("%d ", m1[i][j] - m2[i][j]);
            printf("\n");
        }
    }
    if (m1 != NULL) {
        for (int i = 0; i < satır; i++) free(m1[i]);
